{
    "name": "mediacomptech/demakijo1-konversi",
    "description": "Native PHP MVC Conversion of Demakijo 1",
    "type": "project",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0",
        "eftec/bladeone": "^4.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "exclude-from-classmap": [
            "app/Core/LaravelFacades.php"
        ],
        "files": [
            "app/Helpers/GlobalHelper.php",
            "app/Core/LaravelFacades.php"
        ]
    }
}
